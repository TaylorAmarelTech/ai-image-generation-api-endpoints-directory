# =============================================================================
# AI Image Generation API Endpoints Directory - API Keys
# =============================================================================
# Copy this file to .env and fill in your API keys.
# Only keys for providers you want to test are needed.
# Providers marked "no key" work without authentication.
# =============================================================================

# --- Tier 1: Truly Free ---
HUGGINGFACE_API_KEY=           # https://huggingface.co/settings/tokens
CLOUDFLARE_ACCOUNT_ID=         # https://dash.cloudflare.com/
CLOUDFLARE_API_TOKEN=          # https://dash.cloudflare.com/profile/api-tokens
# Pollinations: no key needed
GOOGLE_API_KEY=                # https://aistudio.google.com/apikey
TOGETHER_API_KEY=              # https://api.together.xyz/settings/api-keys
STABILITY_API_KEY=             # https://platform.stability.ai/account/keys
PRODIA_API_KEY=                # https://app.prodia.com/api
DEZGO_API_KEY=                 # https://dezgo.com/account
STARRYAI_API_KEY=              # https://starryai.com/api
# Craiyon: no key needed
SEGMIND_API_KEY=               # https://www.segmind.com/api-keys

# --- Tier 2: Generous Free Tier ---
LEONARDO_API_KEY=              # https://app.leonardo.ai/api-access
IDEOGRAM_API_KEY=              # https://ideogram.ai/manage-api
LIMEWIRE_API_KEY=              # https://limewire.com/studio

# --- Tier 3: Free Credits on Signup ---
OPENAI_API_KEY=                # https://platform.openai.com/api-keys
FIREWORKS_API_KEY=             # https://fireworks.ai/account/api-keys
REPLICATE_API_TOKEN=           # https://replicate.com/account/api-tokens
DEEPINFRA_API_KEY=             # https://deepinfra.com/dash/api_keys
NOVITA_API_KEY=                # https://novita.ai/dashboard
FAL_KEY=                       # https://fal.ai/dashboard/keys
BFL_API_KEY=                   # https://api.bfl.ml/
SILICONFLOW_API_KEY=           # https://siliconflow.cn/
HYPERBOLIC_API_KEY=            # https://app.hyperbolic.xyz/

# --- Tier 4: Freemium ---
# Midjourney: Discord-based, no standard API key
ADOBE_FIREFLY_CLIENT_ID=       # https://developer.adobe.com/
ADOBE_FIREFLY_CLIENT_SECRET=

# --- Tier 5: Pay-per-use ---
GETIMG_API_KEY=                # https://getimg.ai/dashboard
MONSTER_API_KEY=               # https://monsterapi.ai/

# --- Routers / Aggregators ---
OPENROUTER_API_KEY=            # https://openrouter.ai/keys
EDEN_AI_API_KEY=               # https://www.edenai.run/
AIML_API_KEY=                  # https://aimlapi.com/

# --- Discovery (for AI-powered provider discovery) ---
GROQ_API_KEY=                  # https://console.groq.com/keys
BRAVE_SEARCH_API_KEY=          # https://api.search.brave.com/
SERPER_API_KEY=                # https://serper.dev/
GOOGLE_CSE_API_KEY=            # https://programmablesearchengine.google.com/
GOOGLE_CSE_ID=
